OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1



OPENROUTER_MODELS=poolside/laguna-m.1:free,openai/gpt-oss-20b,mistralai/mistral-small-24b-instruct-2501,qwen/qwen3-235b-a22b-2507

# Optional OpenRouter attribution headers.
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=TR-CodeBench-Proto-100

# Keep defaults small for first real-world smoke tests.
OPENROUTER_ITEM_IDS=
OPENROUTER_N_RUNS=1
OPENROUTER_HIDDEN_CASES=30
OPENROUTER_PBT_CASES=10
OPENROUTER_MAX_TOKENS=12000
OPENROUTER_TEMPERATURE=0.2
OPENROUTER_REQUEST_TIMEOUT=120
OPENROUTER_RATE_LIMIT_SLEEP=0.0
OPENROUTER_MAX_WORKERS=4
OPENROUTER_RETRIES=2
